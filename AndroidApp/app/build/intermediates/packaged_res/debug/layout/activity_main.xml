<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF121628"
    android:padding="20dp">

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI Agent Deck"
        android:textSize="28sp"
        android:textColor="#FF6C8EEF"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BLE 图片/GIF 传输"
        android:textSize="14sp"
        android:textColor="#FF8899BB"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp" />

    <!-- 设备状态卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_device_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未连接"
            android:textSize="18sp"
            android:textColor="#FFF44336"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_connect"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="搜索设备"
            android:textSize="16sp"
            android:layout_marginTop="12dp"
            android:backgroundTint="#FF3D5AFE" />
    </LinearLayout>

    <!-- 图片预览 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/card_bg"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/iv_preview"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_gallery" />

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_gravity="bottom"
            android:visibility="gone"
            android:progressTint="#FF4CAF50"
            android:progressBackgroundTint="#FF333355" />
    </FrameLayout>

    <!-- 操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn_select_image"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="📷 图片"
            android:textSize="15sp"
            android:enabled="false"
            android:backgroundTint="#FF2196F3"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btn_select_gif"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="🎬 GIF"
            android:textSize="15sp"
            android:enabled="false"
            android:backgroundTint="#FFFF9800"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_clear"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="清屏"
        android:textSize="14sp"
        android:enabled="false"
        android:backgroundTint="#FF607D8B" />

    <!-- 状态文字 -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="请先搜索并连接设备"
        android:textSize="13sp"
        android:textColor="#FF8899BB"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp" />

</LinearLayout>
